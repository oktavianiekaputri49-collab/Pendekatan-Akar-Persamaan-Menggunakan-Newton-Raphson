| 5 | 1.71191 | 3.29145 | 33.387% |
| 6 | 1.24591 | 1.56716 | 37.403% |
| 7 | 0.82237 | 0.67069 | 51.502% |
| 8 | 0.50550 | 0.13462 | 62.684% |
| 9 | 0.42593 | -0.00780 | 18.681% |
